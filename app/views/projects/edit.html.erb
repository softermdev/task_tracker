<% content_for :title, "Edit: #{@project.name}" %>

<div class="min-h-screen">
  <div class="sticky top-0 z-20 bg-gray-900/80 backdrop-blur-md border-b border-gray-700/60 pt-6 pb-6 px-6 sm:px-10">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center justify-between">
        <div class="flex items-center">
          <%= link_to @project, class: "mr-4 p-2 rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors" do %>
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
            </svg>
          <% end %>
          <div>
            <h1 class="text-3xl font-bold text-white mb-1 tracking-tight">Edit Project</h1>
            <p class="text-sm text-gray-400 truncate max-w-md"><%= @project.name %></p>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-8 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-64 bg-yellow-500/5 filter blur-[100px] pointer-events-none"></div>

    <div class="relative">
      <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-2xl overflow-hidden">
        
        <div class="bg-gray-800/80 px-8 py-6 border-b border-gray-700/60">
          <div class="flex items-center space-x-4">
            <div class="w-14 h-14 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-xl flex items-center justify-center shadow-lg">
              <svg class="w-7 h-7 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
              </svg>
            </div>
            <div>
              <h2 class="text-xl font-bold text-white">Project Details</h2>
              <p class="text-gray-400 text-sm">Update your project information</p>
            </div>
          </div>
        </div>

        <div class="px-8 py-8">
          <%= form_with(model: @project, class: "space-y-8") do |form| %>
            
            <% if @project.errors.any? %>
              <div class="bg-red-900/20 border border-red-500/30 rounded-xl px-6 py-4 shadow-sm">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-red-400 font-medium text-sm mb-2">
                      <%= pluralize(@project.errors.count, "error") %> prohibited this project from being saved:
                    </h3>
                    <ul class="list-disc list-inside space-y-1">
                      <% @project.errors.each do |error| %>
                        <li class="text-red-300/80 text-sm"><%= error.full_message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="space-y-2.5">
              <%= form.label :name, class: "block text-sm font-semibold text-gray-300 uppercase tracking-wider" do %>
                <div class="flex items-center space-x-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                  </svg>
                  <span>Project Name</span>
                  <span class="text-red-500">*</span>
                </div>
              <% end %>
              <%= form.text_field :name, 
                  class: "w-full px-5 py-3.5 bg-gray-900/50 border border-gray-600 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 focus:ring-2 focus:ring-yellow-500/20 transition-all duration-200",
                  placeholder: "e.g., Website Redesign, Mobile App, Marketing Campaign" %>
              <p class="text-gray-500 text-xs ml-1 font-medium">Choose a clear and descriptive name for your project</p>
            </div>

            <div class="space-y-2.5">
              <%= form.label :description, class: "block text-sm font-semibold text-gray-300 uppercase tracking-wider" do %>
                <div class="flex items-center space-x-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
                  </svg>
                  <span>Description</span>
                </div>
              <% end %>
              <%= form.text_area :description, 
                  rows: 5, 
                  class: "w-full px-5 py-3.5 bg-gray-900/50 border border-gray-600 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 focus:ring-2 focus:ring-yellow-500/20 transition-all duration-200 resize-none",
                  placeholder: "Describe the project goals, scope, and any important details..." %>
              <p class="text-gray-500 text-xs ml-1 font-medium">Help your team understand the project purpose</p>
            </div>

            <div class="border-t border-gray-700/60 pt-6">
              <div class="flex flex-col sm:flex-row gap-4">
                <%= form.submit class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 bg-gradient-to-r from-yellow-400 to-yellow-500 hover:from-yellow-500 hover:to-yellow-600 text-gray-900 rounded-xl transition-all duration-200 font-bold text-base shadow-[0_0_15px_rgba(234,179,8,0.2)] hover:shadow-[0_0_20px_rgba(234,179,8,0.4)] cursor-pointer" do %>
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Save Changes
                <% end %>
                
                <%= link_to @project, class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 bg-gray-700 text-gray-300 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200 font-semibold border border-gray-600" do %>
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                  Cancel
                <% end %>
              </div>
            </div>
          <% end %>
        </div>

        <div class="bg-gray-900/60 px-8 py-4 border-t border-gray-700/60">
          <div class="flex items-center justify-between">
            <div class="flex items-center space-x-2 text-gray-500 text-xs font-medium">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              <span>Fields marked with <span class="text-red-500">*</span> are required</span>
            </div>
            <div class="flex items-center space-x-3 text-gray-500 text-xs">
              <div class="flex items-center space-x-1.5">
                <div class="w-5 h-5 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-full flex items-center justify-center text-gray-900 font-bold text-[8px]">
                  <%= @project.owner.email.first.upcase %>
                </div>
                <span>Owner: <%= @project.owner.email.split('@').first %></span>
              </div>
              <span class="text-gray-600">|</span>
              <span><%= @project.tasks.count %> tasks</span>
              <span class="text-gray-600">|</span>
              <span><%= @project.members.count + 1 %> members</span>
            </div>
          </div>
        </div>
      </div>

      <div class="mt-6">
        <%= button_to project_path(@project), method: :delete, data: { confirm: "Are you sure you want to delete this project? This action cannot be undone." }, class: "w-full group" do %>
          <div class="bg-gray-800/40 rounded-2xl border border-red-500/10 hover:border-red-500/30 p-5 transition-all duration-200 cursor-pointer hover:bg-red-500/5">
            <div class="flex items-center justify-between">
              <div class="flex items-center space-x-3">
                <div class="w-10 h-10 bg-red-500/10 border border-red-500/20 rounded-xl flex items-center justify-center group-hover:bg-red-500/20 transition-colors">
                  <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                  </svg>
                </div>
                <div class="text-left">
                  <p class="text-gray-300 font-semibold text-sm group-hover:text-red-300 transition-colors">Delete Project</p>
                  <p class="text-gray-500 text-xs group-hover:text-red-400/70 transition-colors">Permanently remove this project and all its tasks</p>
                </div>
              </div>
              <svg class="w-5 h-5 text-gray-600 group-hover:text-red-400 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
              </svg>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
