<% content_for :title, @project.name %>

<div class="sticky top-0 z-20 bg-gray-900/80 backdrop-blur-md border-b border-gray-700/60 pt-6 pb-6 px-6 sm:px-10">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 max-w-7xl mx-auto">
    <div class="flex items-center">
      <%= link_to projects_path, class: "mr-4 p-2 rounded-lg bg-gray-800 hover:bg-gray-700 transition-colors" do %>
        <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"></path>
        </svg>
      <% end %>
      <div>
        <h1 class="text-3xl font-bold text-white mb-1 tracking-tight"><%= @project.name %></h1>
        <p class="text-sm text-gray-400"><%= @project.description.presence || "No description" %></p>
      </div>
    </div>
    <div class="flex items-center gap-3">
      <% if can? :update, @project %>
        <%= link_to edit_project_path(@project), class: "inline-flex items-center px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors font-medium" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit
        <% end %>
      <% end %>
      <%= link_to new_project_task_path(@project), class: "inline-flex items-center px-5 py-2 bg-gradient-to-r from-yellow-400 to-yellow-500 hover:from-yellow-500 hover:to-yellow-600 text-gray-900 rounded-lg transition-all duration-200 font-semibold shadow-[0_0_15px_rgba(234,179,8,0.3)] hover:shadow-[0_0_20px_rgba(234,179,8,0.5)]" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        New Task
      <% end %>
      <% if can? :destroy, @project %>
        <%= button_to project_path(@project), method: :delete, data: { confirm: "Are you sure you want to delete this project?" }, class: "p-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-lg transition-colors border border-red-500/20" do %>
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-6 sm:px-10 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-6">
    <!-- Tasks Section -->
    <div class="lg:col-span-3">
      <%= turbo_stream_from @project, "tasks" %>
      
      <!-- Stats Bar -->
      <div class="grid grid-cols-2 md:grid-cols-5 gap-3 mb-6">
        <div class="bg-gray-800/60 p-3 rounded-xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-3">
          <div class="w-10 h-10 bg-gray-700/50 rounded-lg flex items-center justify-center border border-gray-600/50">
            <svg class="w-5 h-5 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
            </svg>
          </div>
          <div>
            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Total</p>
            <p class="text-white text-lg font-black"><%= @tasks.count %></p>
          </div>
        </div>
        
        <div class="bg-gray-800/60 p-3 rounded-xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-3">
          <div class="w-10 h-10 bg-blue-500/10 rounded-lg flex items-center justify-center border border-blue-500/20">
            <span class="w-2.5 h-2.5 bg-blue-400 rounded-full shadow-[0_0_10px_rgba(59,130,246,0.6)]"></span>
          </div>
          <div>
            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">To Do</p>
            <p class="text-white text-lg font-black"><%= @tasks.where(status: 'todo').count %></p>
          </div>
        </div>
        
        <div class="bg-gray-800/60 p-3 rounded-xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-3">
          <div class="w-10 h-10 bg-yellow-500/10 rounded-lg flex items-center justify-center border border-yellow-500/20">
            <span class="w-2.5 h-2.5 bg-yellow-400 rounded-full shadow-[0_0_10px_rgba(250,204,21,0.6)]"></span>
          </div>
          <div>
            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Progress</p>
            <p class="text-white text-lg font-black"><%= @tasks.where(status: 'in_progress').count %></p>
          </div>
        </div>
        
        <div class="bg-gray-800/60 p-3 rounded-xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-3">
          <div class="w-10 h-10 bg-purple-500/10 rounded-lg flex items-center justify-center border border-purple-500/20">
            <span class="w-2.5 h-2.5 bg-purple-400 rounded-full shadow-[0_0_10px_rgba(168,85,247,0.6)]"></span>
          </div>
          <div>
            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Review</p>
            <p class="text-white text-lg font-black"><%= @tasks.where(status: 'review').count %></p>
          </div>
        </div>
        
        <div class="bg-gray-800/60 p-3 rounded-xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-3">
          <div class="w-10 h-10 bg-green-500/10 rounded-lg flex items-center justify-center border border-green-500/20">
            <span class="w-2.5 h-2.5 bg-green-400 rounded-full shadow-[0_0_10px_rgba(74,222,128,0.6)]"></span>
          </div>
          <div>
            <p class="text-gray-400 text-xs font-bold uppercase tracking-wider">Done</p>
            <p class="text-white text-lg font-black"><%= @tasks.where(status: 'done').count %></p>
          </div>
        </div>
      </div>

      <!-- Tasks Table -->
      <div class="bg-gray-800/40 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-700/50 bg-gray-800/60">
                <th class="text-left px-5 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Task</th>
                <th class="text-left px-5 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Status</th>
                <th class="text-left px-5 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Priority</th>
                <th class="text-left px-5 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Assignee</th>
                <th class="text-left px-5 py-4 text-xs font-bold text-gray-400 uppercase tracking-wider">Due Date</th>
              </tr>
            </thead>
            <tbody id="tasks_list" class="divide-y divide-gray-700/30">
              <% if @tasks.any? %>
                <% @tasks.order(created_at: :desc).each do |task| %>
                  <tr class="hover:bg-gray-700/30 transition-colors group">
                    <td class="px-5 py-4">
                      <%= link_to project_task_path(@project, task), class: "text-white font-medium group-hover:text-yellow-400 transition-colors" do %>
                        <%= task.title %>
                      <% end %>
                    </td>
                    <td class="px-5 py-4">
                      <span class="inline-flex items-center px-2.5 py-1 rounded-lg text-xs font-bold border <%= 
                        case task.status
                        when 'todo' then 'bg-blue-500/10 text-blue-400 border-blue-500/20'
                        when 'in_progress' then 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'
                        when 'review' then 'bg-purple-500/10 text-purple-400 border-purple-500/20'
                        when 'done' then 'bg-green-500/10 text-green-400 border-green-500/20'
                        else 'bg-gray-700 text-gray-300 border-gray-600'
                        end
                      %>">
                        <span class="w-1.5 h-1.5 rounded-full mr-1.5 <%= 
                          case task.status
                          when 'todo' then 'bg-blue-400'
                          when 'in_progress' then 'bg-yellow-400'
                          when 'review' then 'bg-purple-400'
                          when 'done' then 'bg-green-400'
                          else 'bg-gray-400'
                          end
                        %>"></span>
                        <%= task.status.humanize %>
                      </span>
                    </td>
                    <td class="px-5 py-4">
                      <% if task.priority %>
                        <span class="px-2.5 py-1 text-xs font-bold uppercase rounded-lg border <%= 
                          case task.priority
                          when 'high' then 'bg-red-500/10 text-red-400 border-red-500/20'
                          when 'medium' then 'bg-yellow-500/10 text-yellow-400 border-yellow-500/20'
                          when 'low' then 'bg-green-500/10 text-green-400 border-green-500/20'
                          else 'bg-gray-700 text-gray-300 border-gray-600'
                          end
                        %>">
                          <%= task.priority %>
                        </span>
                      <% else %>
                        <span class="text-gray-500 text-sm">-</span>
                      <% end %>
                    </td>
                    <td class="px-5 py-4">
                      <% if task.assignee %>
                        <div class="flex items-center">
                          <div class="w-7 h-7 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center text-white text-xs font-bold mr-2">
                            <%= task.assignee.email.first.upcase %>
                          </div>
                          <span class="text-gray-300 text-sm"><%= task.assignee.email.split('@').first %></span>
                        </div>
                      <% else %>
                        <span class="text-gray-500 text-sm">Unassigned</span>
                      <% end %>
                    </td>
                    <td class="px-5 py-4">
                      <% if task.due_date %>
                        <span class="flex items-center text-sm <%= task.overdue? ? 'text-red-400' : 'text-gray-300' %>">
                          <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                          </svg>
                          <%= task.due_date.strftime("%b %d") %>
                          <% if task.overdue? %>
                            <span class="ml-1 text-red-400">(Overdue)</span>
                          <% end %>
                        </span>
                      <% else %>
                        <span class="text-gray-500 text-sm">-</span>
                      <% end %>
                    </td>
                  </tr>
                <% end %>
              <% else %>
                <tr>
                  <td colspan="5" class="px-5 py-16 text-center">
                    <div class="flex flex-col items-center">
                      <div class="w-16 h-16 bg-gray-700/50 rounded-2xl flex items-center justify-center mb-4">
                        <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                        </svg>
                      </div>
                      <p class="text-gray-400 font-medium mb-1">No tasks yet</p>
                      <p class="text-gray-500 text-sm mb-4">Create your first task to get started</p>
                      <%= link_to new_project_task_path(@project), class: "inline-flex items-center px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors text-sm font-medium" do %>
                        <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                        </svg>
                        Create Task
                      <% end %>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      </div>
    </div>

    <!-- Sidebar - Members -->
    <div class="lg:col-span-1">
      <div class="bg-gray-800/40 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg p-5 sticky top-32">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-lg font-bold text-white flex items-center">
            <svg class="w-5 h-5 mr-2 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
            </svg>
            Members
          </h2>
          <span class="px-2 py-1 bg-gray-700 text-gray-300 text-xs font-bold rounded-lg">
            <%= @project.members.count + 1 %>
          </span>
        </div>

        <!-- Member List -->
        <div class="space-y-2 mb-4">
          <!-- Owner -->
          <div class="flex items-center justify-between p-3 bg-yellow-500/5 rounded-xl border border-yellow-500/10">
            <div class="flex items-center">
              <div class="w-9 h-9 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-full flex items-center justify-center text-gray-900 font-bold text-sm shadow-lg">
                <%= @project.owner.email.first.upcase %>
              </div>
              <div class="ml-3">
                <p class="text-white text-sm font-medium"><%= @project.owner.email.split('@').first %></p>
                <p class="text-gray-500 text-xs"><%= @project.owner.email %></p>
              </div>
            </div>
            <span class="px-2 py-1 bg-yellow-500/20 text-yellow-400 text-xs font-bold rounded-md">
              Owner
            </span>
          </div>

          <!-- Members -->
          <% @members.each do |member| %>
            <% next if member.id == @project.owner_id %>
            <div class="flex items-center justify-between p-3 bg-gray-700/30 rounded-xl hover:bg-gray-700/50 transition-colors group">
              <div class="flex items-center">
                <div class="w-9 h-9 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center text-white font-bold text-sm">
                  <%= member.email.first.upcase %>
                </div>
                <div class="ml-3">
                  <p class="text-white text-sm font-medium"><%= member.email.split('@').first %></p>
                  <p class="text-gray-500 text-xs"><%= member.email %></p>
                </div>
              </div>
              <% if can? :destroy, ProjectMember.new(project: @project) %>
                <%= button_to project_project_member_path(@project, @project.project_members.find_by(user: member)), method: :delete, data: { confirm: "Remove #{member.email} from project?" }, class: "p-1.5 text-gray-500 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition-colors opacity-0 group-hover:opacity-100" do %>
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                <% end %>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Add Member Dropdown -->
        <% if can? :create, ProjectMember.new(project: @project) %>
          <div class="border-t border-gray-700/50 pt-4" data-controller="member-search">
            <label class="block text-sm font-medium text-gray-400 mb-2">Add Member</label>
            <div class="relative">
              <input type="text" 
                     id="member-search" 
                     placeholder="Search by email..." 
                     autocomplete="off"
                     class="w-full px-4 py-2.5 bg-gray-700/50 border border-gray-600/50 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-yellow-500/50 focus:border-yellow-500/50 transition-all">
              <svg class="w-4 h-4 absolute right-3 top-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"></path>
              </svg>
              
              <!-- Dropdown Results -->
              <div id="member-results" class="absolute top-full left-0 right-0 mt-2 bg-gray-800 rounded-xl border border-gray-700 shadow-2xl z-50 hidden max-h-64 overflow-y-auto">
                <!-- Results will be populated by JavaScript -->
              </div>
            </div>
          </div>

          <script>
            document.addEventListener('turbo:load', function() {
              const searchInput = document.getElementById('member-search');
              const resultsContainer = document.getElementById('member-results');
              let searchTimeout;
              
              if (!searchInput) return;
              
              searchInput.addEventListener('input', function(e) {
                clearTimeout(searchTimeout);
                const query = e.target.value.trim();
                
                if (query.length < 2) {
                  resultsContainer.classList.add('hidden');
                  resultsContainer.innerHTML = '';
                  return;
                }
                
                searchTimeout = setTimeout(() => {
                  fetch(`/users/search?query=${encodeURIComponent(query)}`)
                    .then(response => response.json())
                    .then(data => {
                      if (data.users && data.users.length > 0) {
                        const existingMemberIds = <%= @project.members.pluck(:id) + [@project.owner_id] %>;
                        const filteredUsers = data.users.filter(u => !existingMemberIds.includes(u.id));
                        
                        if (filteredUsers.length > 0) {
                          resultsContainer.innerHTML = filteredUsers.map(user => `
                            <button type="button"
                                    class="w-full px-4 py-3 text-left hover:bg-gray-700/50 transition-colors flex items-center border-b border-gray-700/50 last:border-b-0"
                                    data-user-id="${user.id}"
                                    data-user-email="${user.email}"
                                    data-action="click->member-search#addMember">
                              <div class="w-8 h-8 bg-gradient-to-br from-blue-400 to-blue-600 rounded-full flex items-center justify-center text-white font-bold text-sm mr-3">
                                ${user.email.charAt(0).toUpperCase()}
                              </div>
                              <div>
                                <p class="text-white text-sm font-medium">${user.email.split('@')[0]}</p>
                                <p class="text-gray-500 text-xs">${user.email}</p>
                              </div>
                              <svg class="w-5 h-5 ml-auto text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                              </svg>
                            </button>
                          `).join('');
                          
                          // Add click handlers
                          resultsContainer.querySelectorAll('button').forEach(btn => {
                            btn.addEventListener('click', function() {
                              const email = this.dataset.userEmail;
                              addMember(email);
                            });
                          });
                          
                          resultsContainer.classList.remove('hidden');
                        } else {
                          resultsContainer.innerHTML = `
                            <div class="px-4 py-3 text-gray-400 text-sm text-center">
                              All matching users are already members
                            </div>
                          `;
                          resultsContainer.classList.remove('hidden');
                        }
                      } else {
                        resultsContainer.innerHTML = `
                          <div class="px-4 py-3 text-gray-400 text-sm text-center">
                            No users found
                          </div>
                        `;
                        resultsContainer.classList.remove('hidden');
                      }
                    })
                    .catch(error => {
                      console.error('Search error:', error);
                    });
                }, 300);
              });
              
              // Hide dropdown when clicking outside
              document.addEventListener('click', function(e) {
                if (!searchInput.contains(e.target) && !resultsContainer.contains(e.target)) {
                  resultsContainer.classList.add('hidden');
                }
              });
              
              function addMember(email) {
                const form = document.createElement('form');
                form.method = 'POST';
                form.action = '<%= project_project_members_path(@project) %>';
                
                const csrfInput = document.createElement('input');
                csrfInput.type = 'hidden';
                csrfInput.name = 'authenticity_token';
                csrfInput.value = document.querySelector('[name="csrf-token"]').content;
                form.appendChild(csrfInput);
                
                const emailInput = document.createElement('input');
                emailInput.type = 'hidden';
                emailInput.name = 'email';
                emailInput.value = email;
                form.appendChild(emailInput);
                
                document.body.appendChild(form);
                form.submit();
              }
            });
          </script>
        <% end %>
      </div>
    </div>
  </div>
</div>
