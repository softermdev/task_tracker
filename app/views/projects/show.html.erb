<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <div>
      <h1 class="text-3xl font-bold"><%= @project.name %></h1>
      <p class="text-gray-600 mt-2"><%= @project.description %></p>
    </div>
    <div class="flex gap-2">
      <% if can? :update, @project %>
        <%= link_to "Edit", edit_project_path(@project), class: "bg-yellow-500 text-white px-4 py-2 rounded hover:bg-yellow-600" %>
      <% end %>
      <% if can? :destroy, @project %>
        <%= button_to "Delete", project_path(@project), method: :delete, data: { confirm: "Are you sure?" }, class: "bg-red-500 text-white px-4 py-2 rounded hover:bg-red-600" %>
      <% end %>
      <%= link_to "Back", projects_path, class: "bg-gray-300 text-gray-700 px-4 py-2 rounded hover:bg-gray-400" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <!-- Tasks Section -->
    <div class="lg:col-span-2">
      <div class="bg-white rounded-lg shadow p-6">
        <div class="flex justify-between items-center mb-4">
          <h2 class="text-2xl font-semibold">Tasks</h2>
          <%= link_to "New Task", new_project_task_path(@project), class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
        </div>

        <% if @tasks.any? %>
          <div class="space-y-4">
            <% @tasks.group_by(&:status).each do |status, tasks| %>
              <div>
                <h3 class="font-semibold text-lg mb-2 capitalize"><%= status.humanize %></h3>
                <div class="space-y-2">
                  <% tasks.each do |task| %>
                    <div class="border rounded p-4 hover:bg-gray-50">
                      <%= link_to task.title, project_task_path(@project, task), class: "text-blue-600 hover:underline font-medium" %>
                      <div class="flex gap-2 mt-2 text-sm">
                        <span class="bg-gray-100 px-2 py-1 rounded"><%= task.priority %></span>
                        <% if task.due_date %>
                          <span class="<%= task.overdue? ? 'bg-red-100 text-red-700' : 'bg-blue-100 text-blue-700' %> px-2 py-1 rounded">
                            <%= task.due_date %>
                          </span>
                        <% end %>
                        <% if task.assignee %>
                          <span class="bg-green-100 text-green-700 px-2 py-1 rounded">
                            <%= task.assignee.email %>
                          </span>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        <% else %>
          <p class="text-gray-500">No tasks yet. Create your first task!</p>
        <% end %>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Members Section -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-xl font-semibold mb-4">Members</h2>
        <ul class="space-y-2 mb-4">
          <li class="flex items-center justify-between">
            <span><%= @project.owner.email %></span>
            <span class="bg-green-100 text-green-800 px-2 py-1 rounded text-sm">Owner</span>
          </li>
          <% @members.each do |member| %>
            <% next if member.id == @project.owner_id %>
            <li class="flex items-center justify-between">
              <span><%= member.email %></span>
              <% if can? :destroy, ProjectMember.new(project: @project) %>
                <%= button_to "Remove", project_project_member_path(@project, @project.project_members.find_by(user: member)), method: :delete, data: { confirm: "Are you sure?" }, class: "text-red-600 text-sm hover:underline" %>
              <% end %>
            </li>
          <% end %>
        </ul>

        <% if can? :create, ProjectMember.new(project: @project) %>
          <%= form_with(url: project_project_members_path(@project), method: :post, class: "mt-4") do |form| %>
            <div class="flex gap-2">
              <%= form.email_field :email, placeholder: "Email", class: "flex-1 px-3 py-2 border border-gray-300 rounded-md text-sm" %>
              <%= form.submit "Add", class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 text-sm cursor-pointer" %>
            </div>
          <% end %>
        <% end %>
      </div>

      <!-- Labels Section -->
      <div class="bg-white rounded-lg shadow p-6">
        <h2 class="text-xl font-semibold mb-4">Labels</h2>
        <% if @project.labels.any? %>
          <div class="flex flex-wrap gap-2 mb-4">
            <% @project.labels.each do |label| %>
              <span class="px-3 py-1 rounded text-white text-sm" style="background-color: <%= label.color %>">
                <%= label.name %>
                <% if can? :destroy, label %>
                  <%= button_to "×", project_label_path(@project, label), method: :delete, class: "inline ml-1 font-bold" %>
                <% end %>
              </span>
            <% end %>
          </div>
        <% end %>

        <% if can? :create, Label.new(project: @project) %>
          <%= form_with(url: project_labels_path(@project), method: :post, class: "space-y-2") do |form| %>
            <%= form.text_field :name, placeholder: "Label name", class: "w-full px-3 py-2 border border-gray-300 rounded-md text-sm" %>
            <%= form.color_field :color, value: "#3b82f6", class: "w-full px-3 py-2 border border-gray-300 rounded-md" %>
            <%= form.submit "Add Label", class: "w-full bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600 text-sm cursor-pointer" %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>
