<% content_for :title, "Projects" %>

<div class="sticky top-0 z-20 bg-gray-900/80 backdrop-blur-md border-b border-gray-700/60 pt-6 pb-6 px-6 sm:px-10">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 max-w-7xl mx-auto">
    <div>
      <h1 class="text-3xl font-bold text-white mb-1 tracking-tight">Projects</h1>
      <p class="text-sm text-gray-400">Manage your projects and collaborate with your team</p>
    </div>
    <div>
      <%= link_to new_project_path, class: "inline-flex items-center px-5 py-2.5 bg-gradient-to-r from-yellow-400 to-yellow-500 hover:from-yellow-500 hover:to-yellow-600 text-gray-900 rounded-lg transition-all duration-200 font-semibold shadow-[0_0_15px_rgba(234,179,8,0.3)] hover:shadow-[0_0_20px_rgba(234,179,8,0.5)] focus:ring-2 focus:ring-yellow-500 focus:ring-offset-2 focus:ring-offset-gray-900" do %>
        <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
        </svg>
        New Project
      <% end %>
    </div>
  </div>
</div>

<div class="max-w-7xl mx-auto px-6 sm:px-10 py-8">
  <!-- Stats Overview -->
  <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mb-8">
    <div class="bg-gray-800/60 p-4 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-4">
      <div class="w-12 h-12 bg-gray-700/50 rounded-xl flex items-center justify-center border border-gray-600/50">
        <svg class="w-6 h-6 text-gray-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
        </svg>
      </div>
      <div>
        <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-0.5">Total</p>
        <p class="text-white text-xl font-black"><%= @owned_projects.count + @member_projects.count %></p>
      </div>
    </div>
    
    <div class="bg-gray-800/60 p-4 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-4">
      <div class="w-12 h-12 bg-yellow-500/10 rounded-xl flex items-center justify-center border border-yellow-500/20">
        <svg class="w-6 h-6 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z"></path>
        </svg>
      </div>
      <div>
        <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-0.5">Owned</p>
        <p class="text-white text-xl font-black"><%= @owned_projects.count %></p>
      </div>
    </div>
    
    <div class="bg-gray-800/60 p-4 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-4">
      <div class="w-12 h-12 bg-blue-500/10 rounded-xl flex items-center justify-center border border-blue-500/20">
        <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
        </svg>
      </div>
      <div>
        <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-0.5">Member</p>
        <p class="text-white text-xl font-black"><%= @member_projects.count %></p>
      </div>
    </div>
    
    <div class="bg-gray-800/60 p-4 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg flex items-center space-x-4">
      <div class="w-12 h-12 bg-green-500/10 rounded-xl flex items-center justify-center border border-green-500/20">
        <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
        </svg>
      </div>
      <div>
        <p class="text-gray-400 text-xs font-bold uppercase tracking-wider mb-0.5">Tasks</p>
        <p class="text-white text-xl font-black"><%= (@owned_projects + @member_projects).sum { |p| p.tasks.count } %></p>
      </div>
    </div>
  </div>

  <!-- Owned Projects Section -->
  <div class="mb-10">
    <div class="flex items-center mb-4">
      <div class="w-1 h-6 bg-yellow-500 rounded-full mr-3"></div>
      <h2 class="text-xl font-bold text-white tracking-tight">My Projects</h2>
      <span class="ml-3 px-2.5 py-1 bg-yellow-500/10 text-yellow-400 text-xs font-bold rounded-lg border border-yellow-500/20">
        <%= @owned_projects.count %>
      </span>
    </div>
    
    <% if @owned_projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @owned_projects.each do |project| %>
          <%= link_to project_path(project), class: "group block" do %>
            <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg hover:shadow-xl hover:border-yellow-500/30 transition-all duration-300 overflow-hidden">
              <div class="p-5">
                <div class="flex items-start justify-between mb-3">
                  <div class="flex items-center">
                    <div class="w-10 h-10 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-xl flex items-center justify-center text-gray-900 font-bold text-lg shadow-lg">
                      <%= project.name.first.upcase %>
                    </div>
                    <div class="ml-3">
                      <h3 class="text-white font-semibold group-hover:text-yellow-400 transition-colors"><%= project.name %></h3>
                      <p class="text-gray-500 text-xs">Owner</p>
                    </div>
                  </div>
                  <span class="px-2.5 py-1 bg-yellow-500/10 text-yellow-400 text-xs font-bold rounded-lg border border-yellow-500/20">
                    Owner
                  </span>
                </div>
                
                <p class="text-gray-400 text-sm mb-4 line-clamp-2 min-h-[40px]">
                  <%= project.description.presence || "No description provided" %>
                </p>
                
                <div class="flex items-center justify-between pt-3 border-t border-gray-700/50">
                  <div class="flex items-center space-x-4 text-sm text-gray-400">
                    <span class="flex items-center">
                      <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                      </svg>
                      <%= project.tasks.count %> tasks
                    </span>
                    <span class="flex items-center">
                      <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                      </svg>
                      <%= project.project_members.count %> members
                    </span>
                  </div>
                  <svg class="w-5 h-5 text-gray-600 group-hover:text-yellow-400 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-800/30 rounded-2xl border border-gray-700/50 border-dashed p-12 text-center">
        <div class="w-16 h-16 bg-gray-700/50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 6v6m0 0v6m0-6h6m-6 0H6"></path>
          </svg>
        </div>
        <p class="text-gray-400 font-medium mb-2">You haven't created any projects yet</p>
        <p class="text-gray-500 text-sm mb-4">Create your first project to start organizing tasks</p>
        <%= link_to new_project_path, class: "inline-flex items-center px-4 py-2 bg-gray-700 hover:bg-gray-600 text-white rounded-lg transition-colors text-sm font-medium" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
          </svg>
          Create Project
        <% end %>
      </div>
    <% end %>
  </div>

  <!-- Member Projects Section -->
  <div>
    <div class="flex items-center mb-4">
      <div class="w-1 h-6 bg-blue-500 rounded-full mr-3"></div>
      <h2 class="text-xl font-bold text-white tracking-tight">Projects I'm In</h2>
      <span class="ml-3 px-2.5 py-1 bg-blue-500/10 text-blue-400 text-xs font-bold rounded-lg border border-blue-500/20">
        <%= @member_projects.count %>
      </span>
    </div>
    
    <% if @member_projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        <% @member_projects.each do |project| %>
          <%= link_to project_path(project), class: "group block" do %>
            <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg hover:shadow-xl hover:border-blue-500/30 transition-all duration-300 overflow-hidden">
              <div class="p-5">
                <div class="flex items-start justify-between mb-3">
                  <div class="flex items-center">
                    <div class="w-10 h-10 bg-gradient-to-br from-blue-400 to-blue-600 rounded-xl flex items-center justify-center text-white font-bold text-lg shadow-lg">
                      <%= project.name.first.upcase %>
                    </div>
                    <div class="ml-3">
                      <h3 class="text-white font-semibold group-hover:text-blue-400 transition-colors"><%= project.name %></h3>
                      <p class="text-gray-500 text-xs">Member</p>
                    </div>
                  </div>
                  <span class="px-2.5 py-1 bg-blue-500/10 text-blue-400 text-xs font-bold rounded-lg border border-blue-500/20">
                    Member
                  </span>
                </div>
                
                <p class="text-gray-400 text-sm mb-4 line-clamp-2 min-h-[40px]">
                  <%= project.description.presence || "No description provided" %>
                </p>
                
                <div class="flex items-center justify-between pt-3 border-t border-gray-700/50">
                  <div class="flex items-center space-x-4 text-sm text-gray-400">
                    <span class="flex items-center">
                      <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                      </svg>
                      <%= project.tasks.count %> tasks
                    </span>
                    <span class="flex items-center">
                      <svg class="w-4 h-4 mr-1.5 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z"></path>
                      </svg>
                      <%= project.project_members.count %> members
                    </span>
                  </div>
                  <svg class="w-5 h-5 text-gray-600 group-hover:text-blue-400 group-hover:translate-x-1 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
                  </svg>
                </div>
              </div>
            </div>
          <% end %>
        <% end %>
      </div>
    <% else %>
      <div class="bg-gray-800/30 rounded-2xl border border-gray-700/50 border-dashed p-12 text-center">
        <div class="w-16 h-16 bg-gray-700/50 rounded-2xl flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
          </svg>
        </div>
        <p class="text-gray-400 font-medium mb-2">You're not a member of any projects yet</p>
        <p class="text-gray-500 text-sm">Projects you join will appear here</p>
      </div>
    <% end %>
  </div>
</div>
