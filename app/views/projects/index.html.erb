<div class="container mx-auto px-4 py-8">
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-3xl font-bold">Projects</h1>
    <%= link_to "New Project", new_project_path, class: "bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
  </div>

  <!-- Owned Projects -->
  <div class="mb-8">
    <h2 class="text-2xl font-semibold mb-4">My Projects</h2>
    <% if @owned_projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @owned_projects.each do |project| %>
          <div class="bg-white rounded-lg shadow p-6 hover:shadow-lg transition">
            <h3 class="text-xl font-semibold mb-2">
              <%= link_to project.name, project_path(project), class: "text-blue-600 hover:underline" %>
            </h3>
            <p class="text-gray-600 mb-4"><%= truncate(project.description, length: 100) %></p>
            <div class="flex justify-between items-center text-sm text-gray-500">
              <span><%= project.tasks.count %> tasks</span>
              <span class="bg-green-100 text-green-800 px-2 py-1 rounded">Owner</span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500">You haven't created any projects yet.</p>
    <% end %>
  </div>

  <!-- Member Projects -->
  <div>
    <h2 class="text-2xl font-semibold mb-4">Projects I'm In</h2>
    <% if @member_projects.any? %>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <% @member_projects.each do |project| %>
          <div class="bg-white rounded-lg shadow p-6 hover:shadow-lg transition">
            <h3 class="text-xl font-semibold mb-2">
              <%= link_to project.name, project_path(project), class: "text-blue-600 hover:underline" %>
            </h3>
            <p class="text-gray-600 mb-4"><%= truncate(project.description, length: 100) %></p>
            <div class="flex justify-between items-center text-sm text-gray-500">
              <span><%= project.tasks.count %> tasks</span>
              <span class="bg-blue-100 text-blue-800 px-2 py-1 rounded">Member</span>
            </div>
          </div>
        <% end %>
      </div>
    <% else %>
      <p class="text-gray-500">You're not a member of any projects yet.</p>
    <% end %>
  </div>
</div>
