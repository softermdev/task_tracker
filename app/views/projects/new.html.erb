<div class="min-h-screen bg-[#39311D]">
  <!-- Header Section -->
  <div class="bg-gradient-to-r from-[#39311D] to-[#4a3f28] border-b border-[#7E7474]/30">
    <div class="container mx-auto px-6 py-6">
      <div class="flex items-center justify-between">
        <div>
          <div class="flex items-center space-x-3 mb-2">
            <%= link_to projects_path, class: "text-[#C4B6B6] hover:text-white transition-colors" do %>
              <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
              </svg>
            <% end %>
            <h1 class="text-3xl font-bold text-[#FFDD93]">New Project</h1>
          </div>
          <p class="text-[#C4B6B6] ml-9">Create a new project to organize your tasks</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Form Section -->
  <div class="container mx-auto px-6 py-8">
    <div class="max-w-2xl mx-auto">
      <!-- Card -->
      <div class="bg-[#7E7474]/10 rounded-2xl border border-[#7E7474]/30 shadow-2xl overflow-hidden">
        <!-- Card Header -->
        <div class="bg-gradient-to-r from-[#7E7474]/20 to-[#7E7474]/10 px-8 py-6 border-b border-[#7E7474]/30">
          <div class="flex items-center space-x-4">
            <div class="w-14 h-14 bg-gradient-to-br from-[#FFDD93] to-[#ffea80] rounded-xl flex items-center justify-center shadow-lg">
              <svg class="w-7 h-7 text-[#39311D]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
              </svg>
            </div>
            <div>
              <h2 class="text-xl font-bold text-white">Project Details</h2>
              <p class="text-[#C4B6B6] text-sm">Fill in the information below</p>
            </div>
          </div>
        </div>

        <!-- Card Body -->
        <div class="px-8 py-8">
          <%= form_with(model: @project, class: "space-y-8") do |form| %>
            <!-- Error Messages -->
            <% if @project.errors.any? %>
              <div class="bg-red-900/30 border border-red-500/50 rounded-xl px-6 py-4">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0">
                    <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-red-400 font-semibold mb-2">
                      <%= pluralize(@project.errors.count, "error") %> prohibited this project from being saved:
                    </h3>
                    <ul class="list-disc list-inside space-y-1">
                      <% @project.errors.each do |error| %>
                        <li class="text-red-300 text-sm"><%= error.full_message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            <% end %>

            <!-- Project Name Field -->
            <div class="space-y-2">
              <%= form.label :name, class: "block text-sm font-semibold text-[#FFDD93] uppercase tracking-wide" do %>
                <div class="flex items-center space-x-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
                  </svg>
                  <span>Project Name</span>
                  <span class="text-red-400">*</span>
                </div>
              <% end %>
              <%= form.text_field :name, 
                  class: "w-full px-5 py-4 bg-[#39311D] border-2 border-[#7E7474]/50 rounded-xl text-white placeholder-[#C4B6B6]/50 focus:outline-none focus:border-[#FFDD93] focus:ring-2 focus:ring-[#FFDD93]/20 transition-all duration-200",
                  placeholder: "e.g., Website Redesign, Mobile App, Marketing Campaign" %>
              <p class="text-[#C4B6B6]/70 text-sm ml-1">Choose a clear and descriptive name for your project</p>
            </div>

            <!-- Description Field -->
            <div class="space-y-2">
              <%= form.label :description, class: "block text-sm font-semibold text-[#FFDD93] uppercase tracking-wide" do %>
                <div class="flex items-center space-x-2">
                  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
                  </svg>
                  <span>Description</span>
                </div>
              <% end %>
              <%= form.text_area :description, 
                  rows: 5, 
                  class: "w-full px-5 py-4 bg-[#39311D] border-2 border-[#7E7474]/50 rounded-xl text-white placeholder-[#C4B6B6]/50 focus:outline-none focus:border-[#FFDD93] focus:ring-2 focus:ring-[#FFDD93]/20 transition-all duration-200 resize-none",
                  placeholder: "Describe the project goals, scope, and any important details..." %>
              <p class="text-[#C4B6B6]/70 text-sm ml-1">Help your team understand the project purpose</p>
            </div>

            <!-- Divider -->
            <div class="border-t border-[#7E7474]/30"></div>

            <!-- Action Buttons -->
            <div class="flex flex-col sm:flex-row gap-4">
              <%= form.submit class: "flex-1 flex items-center justify-center space-x-2 px-6 py-4 bg-gradient-to-r from-[#FFDD93] to-[#ffea80] text-[#39311D] rounded-xl hover:from-[#ffea80] hover:to-[#FFDD93] transition-all duration-200 font-bold text-lg shadow-lg hover:shadow-xl cursor-pointer" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4"></path>
                </svg>
                <span>Create Project</span>
              <% end %>
              
              <%= link_to projects_path, class: "flex-1 flex items-center justify-center space-x-2 px-6 py-4 bg-[#7E7474]/30 text-[#C4B6B6] rounded-xl hover:bg-[#7E7474]/50 hover:text-white transition-all duration-200 font-semibold border border-[#7E7474]/50" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                </svg>
                <span>Cancel</span>
              <% end %>
            </div>
          <% end %>
        </div>

        <!-- Card Footer -->
        <div class="bg-[#39311D]/50 px-8 py-4 border-t border-[#7E7474]/30">
          <div class="flex items-center space-x-2 text-[#C4B6B6]/70 text-sm">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
            <span>Fields marked with <span class="text-red-400">*</span> are required</span>
          </div>
        </div>
      </div>

      <!-- Tips Section -->
      <div class="mt-8 grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-[#7E7474]/10 rounded-xl p-5 border border-[#7E7474]/30">
          <div class="flex items-center space-x-3 mb-2">
            <div class="w-8 h-8 bg-blue-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
              </svg>
            </div>
            <h3 class="text-white font-semibold">Quick Setup</h3>
          </div>
          <p class="text-[#C4B6B6]/70 text-sm">Create a project in seconds with just a name</p>
        </div>

        <div class="bg-[#7E7474]/10 rounded-xl p-5 border border-[#7E7474]/30">
          <div class="flex items-center space-x-3 mb-2">
            <div class="w-8 h-8 bg-purple-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"></path>
              </svg>
            </div>
            <h3 class="text-white font-semibold">Team Collaboration</h3>
          </div>
          <p class="text-[#C4B6B6]/70 text-sm">Invite members to your project after creation</p>
        </div>

        <div class="bg-[#7E7474]/10 rounded-xl p-5 border border-[#7E7474]/30">
          <div class="flex items-center space-x-3 mb-2">
            <div class="w-8 h-8 bg-green-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
              </svg>
            </div>
            <h3 class="text-white font-semibold">Labels & Tasks</h3>
          </div>
          <p class="text-[#C4B6B6]/70 text-sm">Organize work with custom labels and tasks</p>
        </div>
      </div>
    </div>
  </div>
</div>
