<% content_for :title, "Profile" %>

<div class="min-h-screen">
  <div class="sticky top-0 z-20 bg-gray-900/80 backdrop-blur-md border-b border-gray-700/60 pt-6 pb-6 px-6 sm:px-10">
    <div class="max-w-3xl mx-auto">
      <div class="flex items-center">
        <div>
          <h1 class="text-3xl font-bold text-white mb-1 tracking-tight">Profile</h1>
          <p class="text-sm text-gray-400">Manage your account information</p>
        </div>
      </div>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-6 sm:px-10 py-8 relative">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-full h-64 bg-yellow-500/5 filter blur-[100px] pointer-events-none"></div>

    <div class="relative space-y-6">
      <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-2xl overflow-hidden">
        
        <div class="bg-gray-800/80 px-8 py-6 border-b border-gray-700/60">
          <div class="flex items-center space-x-4">
            <div class="w-16 h-16 bg-gradient-to-br from-yellow-400 to-yellow-600 rounded-2xl flex items-center justify-center shadow-lg text-gray-900 text-2xl font-black">
              <%= @user.name.present? ? @user.name[0].upcase : @user.email[0].upcase %>
            </div>
            <div>
              <h2 class="text-xl font-bold text-white"><%= @user.name.presence || @user.email.split('@').first.capitalize %></h2>
              <p class="text-gray-400 text-sm"><%= @user.email %></p>
              <% if @user.admin? %>
                <span class="mt-1 inline-flex items-center px-2 py-0.5 text-[10px] font-bold uppercase rounded-md border bg-red-500/10 text-red-400 border-red-500/20">Admin</span>
              <% end %>
            </div>
          </div>
        </div>

        <div class="px-8 py-8">
          <%= form_with(model: @user, url: profile_path, method: :patch, class: "space-y-6") do |form| %>
            
            <% if @user.errors.any? %>
              <div class="bg-red-900/20 border border-red-500/30 rounded-xl px-5 py-4">
                <div class="flex items-start space-x-3">
                  <div class="flex-shrink-0 mt-0.5">
                    <svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div>
                    <h3 class="text-red-400 font-medium text-sm mb-2">
                      <%= pluralize(@user.errors.count, "error") %> prohibited this profile from being saved:
                    </h3>
                    <ul class="list-disc list-inside space-y-1">
                      <% @user.errors.each do |error| %>
                        <li class="text-red-300/80 text-sm"><%= error.full_message %></li>
                      <% end %>
                    </ul>
                  </div>
                </div>
              </div>
            <% end %>

            <div class="space-y-2">
              <%= form.label :name, class: "block text-sm font-semibold text-gray-300 uppercase tracking-wider" do %>
                <div class="flex items-center space-x-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                  </svg>
                  <span>Display Name</span>
                </div>
              <% end %>
              <%= form.text_field :name, 
                  class: "w-full px-5 py-3.5 bg-gray-900/50 border border-gray-600 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 focus:ring-2 focus:ring-yellow-500/20 transition-all duration-200",
                  placeholder: "Enter your display name" %>
              <p class="text-gray-500 text-xs ml-1 font-medium">This name will be displayed across the app</p>
            </div>

            <div class="space-y-2">
              <%= form.label :email, class: "block text-sm font-semibold text-gray-300 uppercase tracking-wider" do %>
                <div class="flex items-center space-x-2">
                  <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"></path>
                  </svg>
                  <span>Email</span>
                </div>
              <% end %>
              <%= form.email_field :email, 
                  class: "w-full px-5 py-3.5 bg-gray-900/50 border border-gray-600 rounded-xl text-white placeholder-gray-500 focus:outline-none focus:border-yellow-500 focus:ring-2 focus:ring-yellow-500/20 transition-all duration-200",
                  placeholder: "your@email.com" %>
            </div>

            <div class="border-t border-gray-700/60 pt-6">
              <div class="flex flex-col sm:flex-row gap-4">
                <%= form.submit class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 bg-gradient-to-r from-yellow-400 to-yellow-500 hover:from-yellow-500 hover:to-yellow-600 text-gray-900 rounded-xl transition-all duration-200 font-bold text-base shadow-[0_0_15px_rgba(234,179,8,0.2)] hover:shadow-[0_0_20px_rgba(234,179,8,0.4)] cursor-pointer" do %>
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                  </svg>
                  Save Changes
                <% end %>
                
                <%= link_to root_path, class: "flex-1 inline-flex items-center justify-center px-6 py-3.5 bg-gray-700 text-gray-300 rounded-xl hover:bg-gray-600 hover:text-white transition-all duration-200 font-semibold border border-gray-600" do %>
                  <svg class="w-5 h-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
                  </svg>
                  Cancel
                <% end %>
              </div>
            </div>
          <% end %>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="bg-gray-800/40 rounded-xl p-5 border border-gray-700/50">
          <div class="flex items-center space-x-3 mb-2">
            <div class="w-8 h-8 bg-blue-500/10 border border-blue-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
              </svg>
            </div>
            <h3 class="text-gray-300 font-semibold text-sm">Projects</h3>
          </div>
          <p class="text-white text-2xl font-black"><%= @user.owned_projects.count + @user.projects.count %></p>
        </div>

        <div class="bg-gray-800/40 rounded-xl p-5 border border-gray-700/50">
          <div class="flex items-center space-x-3 mb-2">
            <div class="w-8 h-8 bg-yellow-500/10 border border-yellow-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-yellow-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
              </svg>
            </div>
            <h3 class="text-gray-300 font-semibold text-sm">Tasks Created</h3>
          </div>
          <p class="text-white text-2xl font-black"><%= @user.created_tasks.count %></p>
        </div>

        <div class="bg-gray-800/40 rounded-xl p-5 border border-gray-700/50">
          <div class="flex items-center space-x-3 mb-2">
            <div class="w-8 h-8 bg-purple-500/10 border border-purple-500/20 rounded-lg flex items-center justify-center">
              <svg class="w-4 h-4 text-purple-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
              </svg>
            </div>
            <h3 class="text-gray-300 font-semibold text-sm">Comments</h3>
          </div>
          <p class="text-white text-2xl font-black"><%= @user.comments.count %></p>
        </div>
      </div>
    </div>
  </div>
</div>
