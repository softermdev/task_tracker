<div class="task-card bg-[#C4B6B6] rounded-lg p-4 shadow-lg cursor-move hover:shadow-xl transition-shadow border-l-4 border-<%= 
  case task.status
  when 'todo' then 'blue-500'
  when 'in_progress' then 'yellow-500'
  when 'review' then 'purple-500'
  when 'done' then 'green-500'
  end
%>" 
     data-task-id="<%= task.id %>" 
     data-project-id="<%= task.project.id %>"
     draggable="true">
  <%= link_to project_task_path(task.project, task), class: "block" do %>
    <h3 class="text-[#39311D] font-semibold mb-2 <%= 'line-through' if task.status == 'done' %>"><%= task.title %></h3>
    <p class="text-[#39311D]/70 text-sm mb-3"><%= task.project.name %></p>
    <div class="flex items-center justify-between text-xs">
      <div class="flex items-center space-x-2 flex-wrap gap-1">
        <% if task.priority %>
          <span class="px-2 py-1 rounded <%= 
            case task.priority
            when 'high' then 'bg-red-500/20 text-red-700'
            when 'medium' then 'bg-yellow-500/20 text-yellow-700'
            when 'low' then 'bg-green-500/20 text-green-700'
            end
          %>">
            <%= task.priority.upcase %>
          </span>
        <% end %>
        <% if task.assignee %>
          <span class="px-2 py-1 bg-[#39311D]/10 text-[#39311D] rounded flex items-center" title="<%= task.assignee.email %>">
            <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
            <%= task.assignee.email.split('@').first %>
          </span>
        <% end %>
      </div>
      <% if task.due_date %>
        <span class="text-[#39311D]/60 flex items-center <%= 'text-red-700' if task.overdue? %>">
          <svg class="w-3 h-3 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
          </svg>
          <%= task.due_date.strftime("%b %d") %>
        </span>
      <% end %>
    </div>
  <% end %>
</div>
