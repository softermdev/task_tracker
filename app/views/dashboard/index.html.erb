<div class="container mx-auto px-4 py-8">
  <h1 class="text-3xl font-bold mb-6">Dashboard</h1>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
    <!-- My Tasks -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-xl font-semibold mb-4">My Tasks</h2>
      <% if @my_tasks.any? %>
        <ul class="space-y-2">
          <% @my_tasks.each do |task| %>
            <li class="border-b pb-2">
              <%= link_to task.title, project_task_path(task.project, task), class: "text-blue-600 hover:underline" %>
              <span class="text-sm text-gray-500">- <%= task.status %></span>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-gray-500">No tasks assigned</p>
      <% end %>
    </div>

    <!-- Recent Projects -->
    <div class="bg-white rounded-lg shadow p-6">
      <h2 class="text-xl font-semibold mb-4">Recent Projects</h2>
      <% if @recent_projects.any? %>
        <ul class="space-y-2">
          <% @recent_projects.each do |project| %>
            <li class="border-b pb-2">
              <%= link_to project.name, project_path(project), class: "text-blue-600 hover:underline" %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="text-gray-500">No projects yet</p>
      <% end %>
      <%= link_to "Create New Project", new_project_path, class: "mt-4 inline-block bg-blue-500 text-white px-4 py-2 rounded hover:bg-blue-600" %>
    </div>

    <!-- Overdue Tasks -->
    <% if @overdue_tasks.any? %>
      <div class="bg-red-50 rounded-lg shadow p-6">
        <h2 class="text-xl font-semibold mb-4 text-red-700">Overdue Tasks</h2>
        <ul class="space-y-2">
          <% @overdue_tasks.each do |task| %>
            <li class="border-b border-red-200 pb-2">
              <%= link_to task.title, project_task_path(task.project, task), class: "text-red-600 hover:underline" %>
              <span class="text-sm text-red-500">- Due: <%= task.due_date %></span>
            </li>
          <% end %>
        </ul>
      </div>
    <% end %>
  </div>
</div>
