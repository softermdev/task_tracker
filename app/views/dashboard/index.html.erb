<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
document.addEventListener('turbo:load', function() {
  initKanbanBoard();
});

function initKanbanBoard() {
  const dropZones = document.querySelectorAll('.kanban-drop-zone');
  
  dropZones.forEach(zone => {
    new Sortable(zone, {
      group: 'kanban',
      animation: 250,
      ghostClass: 'opacity-30',
      dragClass: 'shadow-2xl scale-105 border-yellow-500',
      handle: '.task-card',
      forceFallback: true,
      onStart: function(evt) {
        evt.item.classList.add('dragging');
        const link = evt.item.querySelector('a');
        if (link) link.style.pointerEvents = 'none';
      },
      onEnd: function(evt) {
        const taskCard = evt.item;
        const taskId = taskCard.dataset.taskId;
        const projectId = taskCard.dataset.projectId;
        const newStatus = evt.to.dataset.status;
        const oldStatus = evt.from.dataset.status;
        
        setTimeout(() => {
          taskCard.classList.remove('dragging');
          const link = taskCard.querySelector('a');
          if (link) link.style.pointerEvents = 'auto';
        }, 200);
        
        if (newStatus === oldStatus) return;
        
        // Optimistic UI update
        updateCounters();
        updateTaskCardBorder(taskCard, newStatus);
        
        fetch(`/projects/${projectId}/tasks/${taskId}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
            'Accept': 'application/json'
          },
          body: JSON.stringify({ task: { status: newStatus } })
        })
        .then(response => {
          if (!response.ok) throw new Error('Network error');
          showToast('Task moved to ' + getStatusLabel(newStatus), 'success');
        })
        .catch(error => {
          console.error('Error updating task:', error);
          if (evt.from && evt.oldIndex !== undefined) {
            evt.from.insertBefore(taskCard, evt.from.children[evt.oldIndex]);
          }
          updateCounters();
          updateTaskCardBorder(taskCard, oldStatus); // Revert style
          showToast('Failed to update task status', 'error');
        });
      }
    });
  });
}

function updateTaskCardBorder(taskCard, status) {
  taskCard.classList.remove('border-l-blue-500', 'border-l-yellow-500', 'border-l-purple-500', 'border-l-green-500', 'opacity-70', 'hover:opacity-100');
  
  const title = taskCard.querySelector('h3');
  if (title) title.classList.remove('text-white', 'text-gray-400', 'line-through', 'group-hover:text-blue-400', 'group-hover:text-yellow-400', 'group-hover:text-purple-400', 'font-semibold', 'font-medium');

  if (status === 'todo') {
    taskCard.classList.add('border-l-blue-500');
    if (title) title.classList.add('text-white', 'font-semibold', 'group-hover:text-blue-400');
  } else if (status === 'in_progress') {
    taskCard.classList.add('border-l-yellow-500');
    if (title) title.classList.add('text-white', 'font-semibold', 'group-hover:text-yellow-400');
  } else if (status === 'review') {
    taskCard.classList.add('border-l-purple-500');
    if (title) title.classList.add('text-white', 'font-semibold', 'group-hover:text-purple-400');
  } else if (status === 'done') {
    taskCard.classList.add('border-l-green-500', 'opacity-70', 'hover:opacity-100');
    if (title) title.classList.add('text-gray-400', 'font-medium', 'line-through');
  }
}

function updateCounters() {
  const statuses = ['todo', 'in_progress', 'review', 'done'];
  
  statuses.forEach(status => {
    const zone = document.querySelector(`.kanban-drop-zone[data-status="${status}"]`);
    if (zone) {
      const cards = zone.querySelectorAll('.task-card');
      const count = cards.length;
      
      const columnBadge = zone.closest('.kanban-column').querySelector('.w-6.h-6');
      if (columnBadge) columnBadge.textContent = count;
      
      const emptyState = zone.querySelector('.empty-state');
      if (emptyState) {
        if (count > 0) {
          emptyState.classList.add('hidden');
        } else {
          emptyState.classList.remove('hidden');
        }
      }
      
      const statsBar = document.querySelector('.grid.grid-cols-2.md\\:grid-cols-5');
      if (statsBar) {
        const statItems = statsBar.querySelectorAll('.bg-gray-800\\/60');
        statItems.forEach(item => {
          const label = item.querySelector('.text-xs');
          if (label) {
            const labelText = label.textContent.toLowerCase();
            if ((status === 'todo' && labelText.includes('to do')) ||
                (status === 'in_progress' && labelText.includes('in progress')) ||
                (status === 'review' && labelText.includes('review')) ||
                (status === 'done' && labelText.includes('done'))) {
              const countElement = item.querySelector('.text-xl');
              if (countElement) countElement.textContent = count;
            }
          }
        });
      }
    }
  });
  
  // Update total
  const totalCount = document.querySelectorAll('.task-card').length;
  const firstStatItem = document.querySelector('.grid.grid-cols-2.md\\:grid-cols-5 .bg-gray-800\\/60:first-child .text-xl');
  if (firstStatItem) firstStatItem.textContent = totalCount;
}

function getStatusLabel(status) {
  const labels = { 'todo': 'To Do', 'in_progress': 'In Progress', 'review': 'Review', 'done': 'Done' };
  return labels[status] || status;
}

function showToast(message, type) {
  let container = document.getElementById('toast-container');
  if (!container) {
    container = document.createElement('div');
    container.id = 'toast-container';
    container.className = 'fixed bottom-5 right-5 z-50 flex flex-col gap-3';
    document.body.appendChild(container);
  }
  
  const toast = document.createElement('div');
  toast.className = `px-6 py-4 rounded-xl shadow-2xl text-white text-sm font-medium border transform transition-all duration-300 flex items-center ${
    type === 'success' ? 'bg-gray-800 border-green-500/30' : 'bg-gray-800 border-red-500/30'
  }`;
  
  toast.innerHTML = `
    ${type === 'success' ? 
      '<div class="w-8 h-8 rounded-full bg-green-500/10 flex items-center justify-center mr-3"><svg class="w-5 h-5 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg></div>' : 
      '<div class="w-8 h-8 rounded-full bg-red-500/10 flex items-center justify-center mr-3"><svg class="w-5 h-5 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg></div>'
    }
    ${message}
  `;
  
  toast.style.animation = 'slideInUp 0.4s cubic-bezier(0.16, 1, 0.3, 1)';
  container.appendChild(toast);
  
  setTimeout(() => {
    toast.style.animation = 'slideOutDown 0.4s cubic-bezier(0.16, 1, 0.3, 1) forwards';
    setTimeout(() => { toast.remove(); }, 400);
  }, 3500);
}

const style = document.createElement('style');
style.textContent = `
  @keyframes slideInUp { from { transform: translateY(100%); opacity: 0; } to { transform: translateY(0); opacity: 1; } }
  @keyframes slideOutDown { from { transform: translateY(0); opacity: 1; } to { transform: translateY(100%); opacity: 0; } }
`;
document.head.appendChild(style);
</script>