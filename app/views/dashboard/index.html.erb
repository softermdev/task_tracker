<!-- Drag and Drop Script -->
<script src="https://cdn.jsdelivr.net/npm/sortablejs@latest/Sortable.min.js"></script>
<script>
document.addEventListener('turbo:load', function() {
  initKanbanBoard();
  updateCounters(); // Update counters on page load to hide/show empty states
});

function initKanbanBoard() {
  const dropZones = document.querySelectorAll('.kanban-drop-zone');
  
  dropZones.forEach(zone => {
    new Sortable(zone, {
      group: 'kanban',
      animation: 200,
      ghostClass: 'opacity-30',
      dragClass: 'shadow-2xl scale-105',
      handle: '.task-card',
      forceFallback: true,
      onStart: function(evt) {
        evt.item.classList.add('dragging');
        // Disable link clicks during drag
        const link = evt.item.querySelector('a');
        if (link) {
          link.style.pointerEvents = 'none';
        }
      },
      onEnd: function(evt) {
        const taskCard = evt.item;
        const taskId = taskCard.dataset.taskId;
        const projectId = taskCard.dataset.projectId;
        const newStatus = evt.to.dataset.status;
        const oldStatus = evt.from.dataset.status;
        
        // Re-enable link clicks after a short delay
        setTimeout(() => {
          taskCard.classList.remove('dragging');
          const link = taskCard.querySelector('a');
          if (link) {
            link.style.pointerEvents = 'auto';
          }
        }, 200);
        
        // If status didn't change, don't make API call
        if (newStatus === oldStatus) {
          return;
        }
        
        // Update task status via AJAX
        fetch(`/projects/${projectId}/tasks/${taskId}`, {
          method: 'PATCH',
          headers: {
            'Content-Type': 'application/json',
            'X-CSRF-Token': document.querySelector('[name="csrf-token"]').content,
            'Accept': 'application/json'
          },
          body: JSON.stringify({
            task: { status: newStatus }
          })
        })
        .then(response => {
          if (!response.ok) {
            throw new Error('Network response was not ok');
          }
          return response.json();
        })
        .then(data => {
          console.log('Task status updated:', data);
          
          // Update counters
          updateCounters();
          
          // Update border color based on new status
          updateTaskCardBorder(taskCard, newStatus);
          
          // Show success message
          showToast('Task moved to ' + getStatusLabel(newStatus), 'success');
        })
        .catch(error => {
          console.error('Error updating task:', error);
          
          // Revert the move on error
          if (evt.from && evt.oldIndex !== undefined) {
            evt.from.insertBefore(taskCard, evt.from.children[evt.oldIndex]);
          }
          
          showToast('Failed to update task status', 'error');
        });
      }
    });
  });
}

function updateTaskCardBorder(taskCard, status) {
  // Remove all border color classes
  taskCard.classList.remove('border-blue-500', 'border-yellow-500', 'border-purple-500', 'border-green-500');
  
  // Add new border color based on status
  const borderColors = {
    'todo': 'border-blue-500',
    'in_progress': 'border-yellow-500',
    'review': 'border-purple-500',
    'done': 'border-green-500'
  };
  
  if (borderColors[status]) {
    taskCard.classList.add(borderColors[status]);
  }
  
  // Add strikethrough for done tasks
  const title = taskCard.querySelector('h3');
  if (title) {
    if (status === 'done') {
      title.classList.add('line-through');
    } else {
      title.classList.remove('line-through');
    }
  }
}

function updateCounters() {
  const statuses = ['todo', 'in_progress', 'review', 'done'];
  
  statuses.forEach(status => {
    const zone = document.querySelector(`.kanban-drop-zone[data-status="${status}"]`);
    if (zone) {
      const count = zone.querySelectorAll('.task-card').length;
      
      // Update column badge (วงกลมมุมขวา)
      const column = zone.closest('.kanban-column');
      if (column) {
        const badge = column.querySelector('.w-8.h-8');
        if (badge) {
          badge.textContent = count;
        }
      }
      
      // Show/Hide "No tasks" message
      const emptyState = zone.querySelector('.text-center.py-12');
      if (emptyState) {
        if (count > 0) {
          emptyState.style.display = 'none';
        } else {
          emptyState.style.display = 'block';
        }
      }
      
      // Update stats bar
      const statsBar = document.querySelector('.grid.grid-cols-2.md\\:grid-cols-5');
      if (statsBar) {
        const statItems = statsBar.querySelectorAll('.flex.items-center.space-x-3');
        statItems.forEach(item => {
          const label = item.querySelector('.text-xs');
          if (label) {
            const labelText = label.textContent.toLowerCase();
            if (
              (status === 'todo' && labelText.includes('to do')) ||
              (status === 'in_progress' && labelText.includes('in progress')) ||
              (status === 'review' && labelText.includes('review')) ||
              (status === 'done' && labelText.includes('done'))
            ) {
              const countElement = item.querySelector('.text-lg.font-bold');
              if (countElement) {
                countElement.textContent = count;
              }
            }
          }
        });
        
        // Update total count
        const totalCount = document.querySelectorAll('.task-card').length;
        const firstStatItem = statsBar.querySelector('.flex.items-center.space-x-3');
        if (firstStatItem) {
          const totalElement = firstStatItem.querySelector('.text-lg.font-bold');
          if (totalElement) {
            totalElement.textContent = totalCount;
          }
        }
      }
    }
  });
}

function getStatusLabel(status) {
  const labels = {
    'todo': 'To Do',
    'in_progress': 'In Progress',
    'review': 'Review',
    'done': 'Done'
  };
  return labels[status] || status;
}

function showToast(message, type) {
  // Check if toast container exists
  let container = document.getElementById('toast-container');
  if (!container) {
    container = document.createElement('div');
    container.id = 'toast-container';
    container.className = 'fixed bottom-5 right-5 z-50 flex flex-col gap-3';
    document.body.appendChild(container);
  }
  
  const toast = document.createElement('div');
  toast.className = `px-6 py-3 rounded-lg shadow-lg text-white transform transition-all duration-300 ${
    type === 'success' ? 'bg-green-600' : 'bg-red-600'
  }`;
  toast.textContent = message;
  toast.style.animation = 'slideIn 0.3s ease-out';
  
  container.appendChild(toast);
  
  setTimeout(() => {
    toast.style.animation = 'fadeOut 0.3s ease-out';
    setTimeout(() => {
      toast.remove();
    }, 300);
  }, 3000);
}

// Prevent accidental navigation during drag
document.addEventListener('click', function(e) {
  const taskCard = e.target.closest('.task-card');
  if (taskCard && taskCard.classList.contains('dragging')) {
    e.preventDefault();
    e.stopPropagation();
    return false;
  }
}, true);
</script>
