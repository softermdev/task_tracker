<aside class="w-64 bg-gray-900 flex-shrink-0 border-r border-gray-800 flex flex-col justify-between hidden md:flex relative z-20">
  <div>
    <div class="h-20 flex items-center px-6 border-b border-gray-800/60">
      <div class="w-8 h-8 rounded-lg bg-gradient-to-br from-yellow-400 to-yellow-600 flex items-center justify-center mr-3 shadow-lg">
        <svg class="w-5 h-5 text-gray-900" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
        </svg>
      </div>
      <span class="text-white text-lg font-bold tracking-wide">Task Tracker</span>
    </div>

    <nav class="p-4 space-y-2 mt-2">
      <%= link_to root_path, class: "flex items-center px-4 py-3 #{current_page?(root_path) || current_page?(dashboard_path) ? 'bg-gray-800/80 text-yellow-500 border border-gray-700/50 shadow-sm' : 'text-gray-400 hover:bg-gray-800/50 hover:text-white'} rounded-xl group transition-all duration-200" do %>
        <svg class="w-5 h-5 mr-3 #{current_page?(root_path) || current_page?(dashboard_path) ? '' : 'group-hover:text-yellow-500 transition-colors'}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path>
        </svg>
        <span class="font-medium">Dashboard</span>
      <% end %>

      <%= link_to projects_path, class: "flex items-center px-4 py-3 #{current_page?(projects_path) || (params[:controller] == 'projects' && params[:action] != 'new') ? 'bg-gray-800/80 text-yellow-500 border border-gray-700/50 shadow-sm' : 'text-gray-400 hover:bg-gray-800/50 hover:text-white'} rounded-xl group transition-all duration-200" do %>
        <svg class="w-5 h-5 mr-3 #{current_page?(projects_path) ? '' : 'group-hover:text-yellow-500 transition-colors'}" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
        </svg>
        <span class="font-medium">Projects</span>
      <% end %>
    </nav>
  </div>

  <div class="p-4 border-t border-gray-800/60 bg-gray-900" data-controller="profile-menu">
    <div class="relative">
      <button type="button" data-action="click->profile-menu#toggle" class="w-full flex items-center p-3 bg-gray-800/40 rounded-xl border border-gray-700/30 hover:bg-gray-800/60 hover:border-gray-600/50 transition-all duration-200 group">
        <div class="w-10 h-10 rounded-full bg-gradient-to-br from-yellow-400 to-yellow-600 flex items-center justify-center text-gray-900 font-bold border-2 border-yellow-500/30 mr-3 flex-shrink-0 shadow-lg">
          <%= current_user&.name.present? ? current_user.name[0].upcase : current_user&.email&.[](0)&.upcase || 'T' %>
        </div>
        <div class="overflow-hidden flex-1 text-left">
          <p class="text-sm font-semibold text-white truncate"><%= current_user&.name.presence || current_user&.email&.split('@')&.first&.capitalize || "User" %></p>
          <p class="text-xs text-gray-500 truncate"><%= current_user&.email || "" %></p>
        </div>
        <svg class="w-4 h-4 text-gray-500 group-hover:text-gray-300 transition-colors flex-shrink-0 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>

      <div data-profile-menu-target="menu" class="absolute bottom-full left-0 right-0 mb-2 bg-gray-800 rounded-xl border border-gray-700/80 shadow-2xl hidden overflow-hidden z-50">
        <%= link_to profile_path, class: "flex items-center px-4 py-3 text-gray-300 hover:bg-gray-700/60 hover:text-white transition-colors" do %>
          <svg class="w-4 h-4 mr-3 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          <span class="text-sm font-medium">Edit Profile</span>
        <% end %>
        <div class="border-t border-gray-700/50"></div>
        <%= button_to destroy_user_session_path, method: :delete, class: "w-full flex items-center px-4 py-3 text-gray-400 hover:bg-red-500/10 hover:text-red-400 transition-colors" do %>
          <svg class="w-4 h-4 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
          </svg>
          <span class="text-sm font-medium">Logout</span>
        <% end %>
      </div>
    </div>
  </div>
</aside>

<script>
document.addEventListener('turbo:load', function() {
  const profileMenu = document.querySelector('[data-controller="profile-menu"]');
  if (!profileMenu) return;

  const toggleBtn = profileMenu.querySelector('[data-action="click->profile-menu#toggle"]');
  const menu = profileMenu.querySelector('[data-profile-menu-target="menu"]');

  toggleBtn.addEventListener('click', function(e) {
    e.stopPropagation();
    menu.classList.toggle('hidden');
  });

  document.addEventListener('click', function(e) {
    if (!profileMenu.contains(e.target)) {
      menu.classList.add('hidden');
    }
  });
});
</script>
