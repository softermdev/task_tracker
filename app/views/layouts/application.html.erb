<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Task Tracker" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Task Tracker">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-[#39311D]">
    <% if user_signed_in? %>
      <nav class="bg-gradient-to-r from-[#39311D] to-[#4a3f28] shadow-2xl border-b border-[#7E7474]/30">
        <div class="container mx-auto px-6">
          <div class="flex justify-between items-center py-4">
            <div class="flex items-center space-x-8">
              <%= link_to root_path, class: "flex items-center space-x-2 group" do %>
                <div class="w-10 h-10 bg-gradient-to-br from-[#FFDD93] to-[#ffea80] rounded-lg flex items-center justify-center shadow-lg">
                  <svg class="w-6 h-6 text-[#39311D]" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"></path>
                  </svg>
                </div>
                <span class="text-2xl font-bold text-white group-hover:text-[#FFDD93] transition-colors">Task Tracker</span>
              <% end %>
              
              <%= link_to dashboard_path, class: "flex items-center space-x-2 px-4 py-2 rounded-lg text-[#C4B6B6] hover:text-white hover:bg-[#7E7474]/30 transition-all duration-200 #{current_page?(dashboard_path) ? 'bg-[#7E7474]/30 text-white' : ''}" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"></path>
                </svg>
                <span class="font-medium">Dashboard</span>
              <% end %>
              
              <%= link_to projects_path, class: "flex items-center space-x-2 px-4 py-2 rounded-lg text-[#C4B6B6] hover:text-white hover:bg-[#7E7474]/30 transition-all duration-200 #{current_page?(projects_path) ? 'bg-[#7E7474]/30 text-white' : ''}" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
                </svg>
                <span class="font-medium">Projects</span>
              <% end %>
            </div>
            
            <div class="flex items-center space-x-4">
              <div class="hidden md:flex items-center space-x-3 px-4 py-2 bg-[#7E7474]/30 rounded-lg border border-[#7E7474]/50">
                <div class="w-8 h-8 bg-gradient-to-br from-[#FFDD93] to-[#ffea80] rounded-full flex items-center justify-center">
                  <span class="text-[#39311D] font-bold text-sm"><%= current_user.email[0].upcase %></span>
                </div>
                <div>
                  <p class="text-white text-sm font-medium"><%= current_user.email.split('@').first.capitalize %></p>
                  <p class="text-[#C4B6B6] text-xs"><%= current_user.email %></p>
                </div>
              </div>
              
              <% if current_user.admin? %>
                <span class="px-3 py-1 bg-red-500/20 text-red-400 rounded-lg text-sm font-semibold border border-red-500/50">Admin</span>
              <% end %>
              
              <%= button_to destroy_user_session_path, method: :delete, class: "flex items-center space-x-2 px-4 py-2 bg-red-500/20 text-red-400 rounded-lg hover:bg-red-500 hover:text-white transition-all duration-200 border border-red-500/50 hover:border-red-500" do %>
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
                </svg>
                <span class="font-medium">Logout</span>
              <% end %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <!-- Toast Notifications -->
    <div id="toast-container" class="fixed right-5 bottom-5 z-50 flex flex-col gap-3 pointer-events-none">
      <% flash.each do |type, message| %>
        <div class="toast-notification pointer-events-auto transform transition-all duration-300 ease-out" 
             data-type="<%= type %>"
             style="animation: slideIn 0.3s ease-out, fadeOut 0.4s ease-in 4s forwards;">
          <div class="flex items-start gap-3 min-w-[320px] max-w-md p-4 rounded-xl shadow-2xl backdrop-blur-sm border
                      <%= type == 'notice' ? 'bg-gradient-to-r from-green-900/95 to-green-800/95 border-green-600/50' : 
                          type == 'alert' ? 'bg-gradient-to-r from-red-900/95 to-red-800/95 border-red-600/50' : 
                          type == 'success' ? 'bg-gradient-to-r from-yellow-900/95 to-yellow-800/95 border-yellow-600/50' :
                          'bg-gradient-to-r from-gray-900/95 to-gray-800/95 border-gray-600/50' %>">
            <!-- Icon -->
            <div class="flex-shrink-0 mt-0.5">
              <% if type == 'notice' || type == 'success' %>
                <svg class="w-6 h-6 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              <% elsif type == 'alert' || type == 'error' %>
                <svg class="w-6 h-6 text-red-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              <% else %>
                <svg class="w-6 h-6 text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
              <% end %>
            </div>
            
            <!-- Message -->
            <div class="flex-1 pt-0.5">
              <p class="text-sm font-medium text-white leading-relaxed">
                <%= message %>
              </p>
            </div>
            
            <!-- Close Button -->
            <button onclick="this.closest('.toast-notification').style.animation='fadeOut 0.2s ease-out forwards'" 
                    class="flex-shrink-0 text-gray-400 hover:text-white transition-colors duration-200">
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
              </svg>
            </button>
          </div>
        </div>
      <% end %>
    </div>

    <%= yield %>

    <style>
      @keyframes slideIn {
        from {
          transform: translateX(120%);
          opacity: 0;
        }
        to {
          transform: translateX(0);
          opacity: 1;
        }
      }
      
      @keyframes fadeOut {
        to {
          opacity: 0;
          transform: translateX(120%);
        }
      }
      
      .toast-notification {
        animation: slideIn 0.3s ease-out;
      }
    </style>
  </body>
</html>
