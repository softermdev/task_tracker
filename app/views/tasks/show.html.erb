<% content_for :title, @task.title %>

<% status_color = case @task.status when 'todo' then 'blue' when 'in_progress' then 'yellow' when 'review' then 'purple' when 'done' then 'green' else 'gray' end %>
<% priority_color = case @task.priority when 'high' then 'red' when 'medium' then 'yellow' when 'low' then 'green' else 'gray' end %>

<div class="sticky top-0 z-20 bg-gray-900/80 backdrop-blur-md border-b border-gray-700/60 pt-6 pb-6 px-6 sm:px-10">
  <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4 max-w-5xl mx-auto">
    <div class="flex items-center gap-3 min-w-0">
      <%= link_to @project, class: "flex-shrink-0 p-2 text-gray-400 hover:text-white hover:bg-gray-800 rounded-lg transition-colors" do %>
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
        </svg>
      <% end %>
      <div class="min-w-0">
        <div class="flex items-center gap-2 mb-1">
          <span class="w-2.5 h-2.5 bg-<%= status_color %>-500 rounded-full"></span>
          <p class="text-gray-400 text-xs font-bold uppercase tracking-wider"><%= @task.status.humanize %></p>
          <% if @task.priority %>
            <span class="px-2 py-0.5 text-[10px] font-bold uppercase rounded-md border bg-<%= priority_color %>-500/10 text-<%= priority_color %>-400 border-<%= priority_color %>-500/20"><%= @task.priority %></span>
          <% end %>
        </div>
        <h1 class="text-2xl font-bold text-white tracking-tight truncate"><%= @task.title %></h1>
      </div>
    </div>
    <div class="flex items-center gap-2 flex-shrink-0">
      <% if can? :update, @task %>
        <%= link_to edit_project_task_path(@project, @task), class: "inline-flex items-center px-4 py-2 bg-gray-800 hover:bg-gray-700 text-gray-200 rounded-lg transition-all duration-200 text-sm font-medium border border-gray-700" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z"></path>
          </svg>
          Edit
        <% end %>
      <% end %>
      <% if can? :destroy, @task %>
        <%= button_to project_task_path(@project, @task), method: :delete, data: { confirm: "Are you sure?" }, class: "inline-flex items-center px-4 py-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-lg transition-all duration-200 text-sm font-medium border border-red-500/20" do %>
          <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Delete
        <% end %>
      <% end %>
    </div>
  </div>
</div>

<div class="max-w-5xl mx-auto px-6 sm:px-10 py-8">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg p-6">
        <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3 flex items-center">
          <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h7"></path>
          </svg>
          Description
        </h2>
        <p class="text-gray-300 leading-relaxed"><%= @task.description.presence || content_tag(:span, "No description provided", class: "text-gray-500 italic") %></p>
      </div>

      <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg p-6">
        <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4 flex items-center">
          <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          Comments
          <span class="ml-2 w-6 h-6 flex items-center justify-center bg-gray-900 text-gray-400 rounded-md text-xs font-bold border border-gray-700"><%= @comments.count %></span>
        </h2>

        <% if can? :create, Comment.new(task: @task) %>
          <%= form_with(url: project_task_comments_path(@project, @task), scope: :comment, method: :post, class: "mb-5") do |form| %>
            <div class="relative">
              <%= form.text_area :content, rows: 3, class: "w-full px-4 py-3 bg-gray-900/80 border border-gray-700 rounded-xl text-gray-200 placeholder-gray-500 focus:outline-none focus:ring-2 focus:ring-#{status_color}-500/50 focus:border-#{status_color}-500/50 transition-colors resize-none text-sm", placeholder: "Add a comment..." %>
            </div>
            <div class="flex justify-end mt-2">
              <%= form.submit "Add Comment", class: "inline-flex items-center px-4 py-2 bg-gradient-to-r from-#{status_color}-500 to-#{status_color}-600 hover:from-#{status_color}-600 hover:to-#{status_color}-700 text-white rounded-lg transition-all duration-200 text-sm font-medium cursor-pointer" %>
            </div>
          <% end %>
        <% end %>

        <div class="space-y-3">
          <% @comments.each do |comment| %>
            <div class="bg-gray-900/60 rounded-xl p-4 border border-gray-700/40 group">
              <div class="flex justify-between items-start mb-2">
                <div class="flex items-center gap-2">
                  <div class="w-7 h-7 rounded-full bg-gradient-to-br from-gray-600 to-gray-700 flex items-center justify-center text-xs font-bold text-gray-300 border border-gray-600/50">
                    <%= comment.user.email[0].upcase %>
                  </div>
                  <div>
                    <span class="text-gray-200 text-sm font-medium"><%= comment.user.email %></span>
                    <span class="text-gray-500 text-xs ml-2"><%= time_ago_in_words(comment.created_at) %> ago</span>
                  </div>
                </div>
                <% if can? :destroy, comment %>
                  <%= button_to project_task_comment_path(@project, @task, comment), method: :delete, data: { confirm: "Are you sure?" }, class: "p-1.5 text-gray-600 hover:text-red-400 hover:bg-red-500/10 rounded-lg transition-all opacity-0 group-hover:opacity-100" do %>
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
                    </svg>
                  <% end %>
                <% end %>
              </div>
              <p class="text-gray-300 text-sm leading-relaxed pl-9"><%= comment.content %></p>
            </div>
          <% end %>
        </div>

        <% if @comments.empty? %>
          <div class="text-center py-10 text-gray-500">
            <svg class="w-10 h-10 mx-auto mb-3 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
            <p class="text-sm font-medium">No comments yet</p>
            <p class="text-xs mt-1">Be the first to comment!</p>
          </div>
        <% end %>
      </div>
    </div>

    <div class="space-y-6">
      <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg p-6">
        <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">Details</h2>
        <div class="space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-gray-500 text-sm flex items-center">
              <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
              </svg>
              Status
            </span>
            <span class="px-2.5 py-1 text-xs font-bold uppercase rounded-md border bg-<%= status_color %>-500/10 text-<%= status_color %>-400 border-<%= status_color %>-500/20">
              <%= @task.status.humanize %>
            </span>
          </div>

          <% if @task.priority %>
            <div class="flex items-center justify-between">
              <span class="text-gray-500 text-sm flex items-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                </svg>
                Priority
              </span>
              <span class="px-2.5 py-1 text-xs font-bold uppercase rounded-md border bg-<%= priority_color %>-500/10 text-<%= priority_color %>-400 border-<%= priority_color %>-500/20">
                <%= @task.priority.humanize %>
              </span>
            </div>
          <% end %>

          <% if @task.due_date %>
            <div class="flex items-center justify-between">
              <span class="text-gray-500 text-sm flex items-center">
                <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
                </svg>
                Due Date
              </span>
              <span class="text-sm font-medium <%= @task.overdue? ? 'text-red-400' : 'text-gray-200' %>">
                <%= @task.due_date.strftime("%b %d, %Y") %>
                <% if @task.overdue? %>
                  <span class="text-[10px] uppercase font-bold ml-1">(Overdue)</span>
                <% end %>
              </span>
            </div>
          <% end %>
        </div>
      </div>

      <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg p-6">
        <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-4">People</h2>
        <div class="space-y-3">
          <div class="flex items-center gap-3">
            <div class="w-8 h-8 rounded-full bg-gradient-to-br from-blue-600 to-blue-700 flex items-center justify-center text-xs font-bold text-white border border-blue-500/30">
              <%= @task.creator.email[0].upcase %>
            </div>
            <div>
              <p class="text-xs text-gray-500">Created by</p>
              <p class="text-sm text-gray-200 font-medium"><%= @task.creator.email %></p>
            </div>
          </div>
          <div class="border-t border-gray-700/40"></div>
          <div class="flex items-center gap-3">
            <% if @task.assignee %>
              <div class="w-8 h-8 rounded-full bg-gradient-to-br from-purple-600 to-purple-700 flex items-center justify-center text-xs font-bold text-white border border-purple-500/30">
                <%= @task.assignee.email[0].upcase %>
              </div>
              <div>
                <p class="text-xs text-gray-500">Assigned to</p>
                <p class="text-sm text-gray-200 font-medium"><%= @task.assignee.email %></p>
              </div>
            <% else %>
              <div class="w-8 h-8 rounded-full bg-gray-700 flex items-center justify-center border border-gray-600/50">
                <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                </svg>
              </div>
              <div>
                <p class="text-xs text-gray-500">Assigned to</p>
                <p class="text-sm text-gray-400 italic">Unassigned</p>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <% if @task.labels.any? %>
        <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg p-6">
          <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3 flex items-center">
            <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z"></path>
            </svg>
            Labels
          </h2>
          <div class="flex flex-wrap gap-2">
            <% @task.labels.each do |label| %>
              <span class="px-3 py-1 rounded-lg text-xs font-semibold border border-white/10" style="background-color: <%= label.color %>20; color: <%= label.color %>; border-color: <%= label.color %>40">
                <%= label.name %>
              </span>
            <% end %>
          </div>
        </div>
      <% end %>

      <div class="bg-gray-800/60 rounded-2xl border border-gray-700/50 backdrop-blur-sm shadow-lg p-6">
        <h2 class="text-sm font-bold text-gray-400 uppercase tracking-wider mb-3 flex items-center">
          <svg class="w-4 h-4 mr-2 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
          </svg>
          Project
        </h2>
        <%= link_to @project, class: "flex items-center gap-2 text-sm text-gray-200 hover:text-blue-400 transition-colors group" do %>
          <svg class="w-4 h-4 text-gray-500 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"></path>
          </svg>
          <%= @project.name %>
          <svg class="w-3 h-3 text-gray-600 group-hover:text-blue-400 group-hover:translate-x-0.5 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"></path>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
</div>
